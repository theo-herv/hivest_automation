# Clé API Groq — gratuite, sans carte bancaire (https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Bonus 1 - alerte urgente (choisis un canal, Telegram est le plus rapide à mettre en place)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bonus 2 - délai avant relance (en millisecondes)
# 86400000 = 1 jour (valeur réelle)
# 30000 = 30 secondes (pour la démo live)
FOLLOWUP_DELAY_MS=30000

PORT=3000
